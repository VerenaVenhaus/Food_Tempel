# Vorlage. Kopiere zu .env und trage die echten Werte ein.
# Auf Production (Railway/Render) werden diese als Environment Variables gesetzt,
# nicht als Datei.

# Port, auf dem der Server lauscht. Lokal 3000 — Production setzt PORT selbst.
PORT=3000

# Supabase-Konfiguration. Server prüft damit, ob ein eingehender Request
# von einem authentifizierten User kommt. URL ist dieselbe wie in der App.
# Der service_role-Key ist GEHEIM und darf nur hier liegen, NIE im Client.
SUPABASE_URL=https://EXAMPLE.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs.example.SERVICE.key

# Google Gemini — kostenloser Free Tier, für die KI-Extraktion.
# Key holen: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# CORS — welche Origins dürfen das Backend aufrufen?
# Während der Entwicklung: alle. In Production: nur die App-Domain.
ALLOWED_ORIGINS=*
