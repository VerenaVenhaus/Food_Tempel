# Supabase-Konfiguration für Auth, Storage und Sync.
# Werte aus dem Supabase-Dashboard → Project Settings → API kopieren.
#
# WICHTIG: Diese Datei ist eine VORLAGE. Lege eine echte Datei namens ".env"
# (ohne .example) im selben Ordner an und trage deine Keys dort ein.
# Der EXPO_PUBLIC_-Prefix ist erforderlich, damit die Werte ins App-Bundle
# kommen. (Native Apps können keine Server-Side env vars lesen.)

EXPO_PUBLIC_SUPABASE_URL=https://EXAMPLE.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs.example.key
